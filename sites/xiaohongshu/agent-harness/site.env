# Site-specific browser flags for cli-anyweb-xiaohongshu.
# Fill in a real desktop Chrome UA before probing the public home page.
# Example:
CLI_ANYWEB_AGENT_BROWSER_FLAGS='--user-agent "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36"'
# Show a visible browser window for manual login.
# AGENT_BROWSER_HEADED=true
# Optional: reuse an explicit browser profile directory across sessions.
# CLI_ANYWEB_SITE_PROFILE_DIR='Y:\gui-agent-harness\sites\xiaohongshu\agent-harness\.agent-browser-profile'
